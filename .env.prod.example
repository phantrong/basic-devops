# Copy sang .env.prod rồi chỉnh khi deploy thật:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Mật khẩu MySQL (đổi thành mật khẩu mạnh khi public!)
DB_PASSWORD=password
DB_NAME=appdb

# URL backend mà TRÌNH DUYỆT của người dùng gọi tới (baked vào lúc build frontend).
# Local: http://localhost:4000  —  Prod: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:4000
